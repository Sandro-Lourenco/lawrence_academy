# Lawrence Academy Monorepo Gitignore

# Environment Secrets
.env
.env.*
!.env.example

# IDEs & Editor Configuration
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Python Dependencies & Caches
__pycache__/
*.py[cod]
*$py.test
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
ENV/

# Dart & Flutter Build Files
.dart_tool/
.pub-cache/
.pub/
build/
*.flutter-plugins
*.flutter-plugins-dependencies
*.flutter-plugins-dependencies.lock
*.flutter-plugins.lock

# Node.js
node_modules/

# Test Coverage
coverage/
*.lcov

# Temporary files & logs
*.log
.temp/
supabase/.temp/
Thumbs.db
.DS_Store
